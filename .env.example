# Copy this file to ".env" and fill in your key.
# Free API key from https://www.api-football.com/  (api-sports.io)
# Only needed to fetch fresh results via src/livedata.py — the committed
# data/live_results.csv already lets you run everything without a key.
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io
