# Copy this file to ".env" and fill in your key.
# Free API key from https://www.api-football.com/  (api-sports.io)
# Only needed to fetch fresh results via src/livedata.py - the committed
# data/live_results.csv already lets you run everything without a key.
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io

# Optional: free token from https://www.football-data.org/  - if set, src/knockout.py
# pulls Round-of-32 fixtures from football-data.org instead of fixturedownload.com
# (only works if their free tier covers the World Cup; otherwise it falls back).
# FOOTBALL_DATA_TOKEN=your_token_here
